<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS (LTR) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        integrity="sha384-..." crossorigin="anonymous">

    <title>Contact Us</title>
</head>

<body>
        <form method="post" class="container my-4" style="height: 85vh;">
            <div class="mb-3">
                <label for="exampleFormControlInput1" class="form-label">Email address</label>
                <input type="email" name="email" class="form-control" id="exampleFormControlInput1" placeholder="name@example.com" value="<%= condata.email %>" >
            </div>
            <div class="mb-3">
                <label for="exampleFormControlInput1" class="form-label">Phone number</label>
                <input type="tyl" name="phone" class="form-control" placeholder="Enter Your Number" value="<%= condata.phone %>">
            </div>
            <div class="mb-3">
                <label for="exampleFormControlSelect1" class="form-label">Select your Query</label>
                <select class="form-select" name="query" id="exampleFormControlSelect1" value="<%= condata.query %>">
                    <option>1</option>
                    <option>2</option>
                    <option>3</option>
                    <option>4</option>
                    <option>5</option>
                </select>
            </div>
            <div class="form-group row mb-3">
                <div class="col-sm-2">Are You a Member</div>
                <div class="col-sm-10">
                    <div class="form-check">
                        <input class="form-check-input" name="member" type="checkbox" id="gridCheck1" value="<%= condata.member %>">
                        <label class="form-check-label" for="gridCheck1">
                            yes
                        </label>
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label for="exampleFormControlTextarea1" class="form-label">Elaborate Your Concern</label>
                <textarea class="form-control" name="concern" id="exampleFormControlTextarea1" value="<%= condata.concern %>" rows="3"></textarea>
            </div>
            <button type="submit" class="btn w-100 text-white fw-bold"
                style="background: linear-gradient(to right, #00e6e6, #00cc99);">Edit</button>

        </form>

            <!-- Bootstrap Bundle with Popper -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"
                integrity="sha384-..." crossorigin="anonymous"></script>
</body>

</html>