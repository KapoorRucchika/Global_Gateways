<html>

<head>
    <title>Home Page - Global Gateways</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

</head>

<body>
    <%- include ("./common/header.ejs") %>
        <div id="carouselExampleSlidesOnly" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img src="images/img1.jpg" style="width: 100%; height: 650px;" class="d-block mx-auto" alt="...">

                </div>
                <div class="carousel-item">
                    <img src="images/img2.jpg" style="width: 100%; height: 650px;" class="d-block mx-auto" alt="...">

                </div>
                <div class="carousel-item">
                    <img src="images/img3.jpg" style="width: 100%; height: 650px;" class="d-block mx-auto" alt="...">

                </div>
            </div>
            <!-- Welcome Section -->
            <div class="container my-5 text-center">
                <h1>Welcome to Global Gateways</h1>
                <p class="lead">Your gateway to unforgettable travel experiences. Discover, explore, and enjoy curated
                    packages designed just for you.</p>
            </div>

            <!-- Popular Destinations -->
            <div class="container my-5">
                <h2 class="text-center mb-4">Popular Destinations</h2>
                <div class="row text-center">
                    <div class="col-md-4 mb-4">
                        <img src="images/pic1.jpg" class="img-fluid rounded shadow" alt="Paris">
                        <h5 class="mt-3">Paris, France</h5>
                    </div>
                    <div class="col-md-4 mb-4">
                        <img src="images/pic2.jpg" class="img-fluid rounded shadow" style="width: 450px;" alt="Bali">
                        <h5 class="mt-3">Bali, Indonesia</h5>
                    </div>
                    <div class="col-md-4 mb-4">
                        <img src="images/pic3.jpg" class="img-fluid rounded shadow" style="width: 370px;" alt="New York">
                        <h5 class="mt-3">New York, USA</h5>
                    </div>
                </div>
            </div>

            <!-- Why Choose Us Section -->
            <div class="bg-light py-5">
                <div class="container">
                    <h2 class="text-center mb-4">Why Choose Us</h2>
                    <div class="row text-center">
                        <div class="col-md-4">
                            <i class="fas fa-globe fa-2x mb-2 text-primary"></i>
                            <h5>Global Destinations</h5>
                            <p>We offer packages to over 50 countries worldwide.</p>
                        </div>
                        <div class="col-md-4">
                            <i class="fas fa-hand-holding-usd fa-2x mb-2 text-success"></i>
                            <h5>Affordable Prices</h5>
                            <p>Best value for money with no hidden costs.</p>
                        </div>
                        <div class="col-md-4">
                            <i class="fas fa-headset fa-2x mb-2 text-warning"></i>
                            <h5>24/7 Support</h5>
                            <p>We’re here to help anytime you need us.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Call to Action -->
            <div class="container text-center my-5">
                <h2>Ready to Start Your Journey?</h2>
                <p>Explore our travel packages and find your perfect escape.</p>
                <a href="/packages" class="btn btn-primary btn-lg mt-3">View Packages</a>
            </div>

        </div>








        <%- include ("./common/footer.ejs") %>
</body>

</html>