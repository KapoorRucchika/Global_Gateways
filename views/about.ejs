<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>About Us - Global Gateways</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons (optional for visuals) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        .hero {
            background: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e') center center/cover no-repeat;
            height: 400px;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);
        }

        .hero h1 {
            font-size: 3rem;
            font-weight: bold;
        }

        .section-title {
            font-weight: 600;
            margin-bottom: 30px;
        }
    </style>
</head>

<body>

    <!-- Header Include -->
    <%- include ("./common/header.ejs") %>

        <!-- Hero Section -->
        <section class="hero">
            <div class="text-center">
                <h1>About Global Gateways</h1>
                <p class="lead">Your companion for unforgettable journeys</p>
            </div>
        </section>

        <!-- About Content -->
        <section class="py-5">
            <div class="container">
                <h2 class="text-center section-title">Who We Are</h2>
                <div class="row align-items-center">
                    <div class="col-md-6" style="width: 550px;">
                        <img src="https://images.unsplash.com/photo-1506765515384-028b60a970df?auto=format&fit=crop&w=800&q=80"
                            alt="Travel Team" class="img-fluid rounded shadow-sm">

                    </div>
                    <div class="col-md-6 mt-4 mt-md-0">
                        <p>
                            Global Gateways is a passionate team of travel experts who believe in creating unique and
                            unforgettable experiences
                            for our travelers. From hidden gems to iconic destinations, we help you explore the world
                            with confidence.
                        </p>
                        <p>
                            With a commitment to excellence and personalized service, we aim to be your trusted travel
                            partner every step
                            of the way.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Meet the Team -->
        <section class="py-5 bg-light">
            <div class="container">
                <h2 class="text-center section-title">Meet Our Team</h2>
                <p class="text-center text-muted mb-5">The people behind your dream journeys</p>

                <div class="row g-4 justify-content-center">

                    <!-- Team Member 1 -->
                    <div class="col-md-4 col-sm-6">
                        <div class="card border-0 shadow-sm text-center">
                            <img src="https://randomuser.me/api/portraits/women/44.jpg"
                                class="card-img-top rounded-circle mx-auto mt-4"
                                style="width: 120px; height: 120px; object-fit: cover;" alt="Sarah">
                            <div class="card-body">
                                <h5 class="card-title mb-1">Sarah Thompson</h5>
                                <p class="text-muted small">Travel Consultant</p>
                                <div>
                                    <a href="#" class="text-primary me-2"><i class="bi bi-facebook"></i></a>
                                    <a href="#" class="text-danger me-2"><i class="bi bi-instagram"></i></a>
                                    <a href="#" class="text-info"><i class="bi bi-linkedin"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Team Member 2 -->
                    <div class="col-md-4 col-sm-6">
                        <div class="card border-0 shadow-sm text-center">
                            <img src="https://randomuser.me/api/portraits/men/35.jpg"
                                class="card-img-top rounded-circle mx-auto mt-4"
                                style="width: 120px; height: 120px; object-fit: cover;" alt="Alex">
                            <div class="card-body">
                                <h5 class="card-title mb-1">Alex Garcia</h5>
                                <p class="text-muted small">Destination Specialist</p>
                                <div>
                                    <a href="#" class="text-primary me-2"><i class="bi bi-facebook"></i></a>
                                    <a href="#" class="text-danger me-2"><i class="bi bi-instagram"></i></a>
                                    <a href="#" class="text-info"><i class="bi bi-linkedin"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Team Member 3 -->
                    <div class="col-md-4 col-sm-6">
                        <div class="card border-0 shadow-sm text-center">
                            <img src="https://randomuser.me/api/portraits/women/68.jpg"
                                class="card-img-top rounded-circle mx-auto mt-4"
                                style="width: 120px; height: 120px; object-fit: cover;" alt="Priya">
                            <div class="card-body">
                                <h5 class="card-title mb-1">Priya Mehta</h5>
                                <p class="text-muted small">Customer Experience Manager</p>
                                <div>
                                    <a href="#" class="text-primary me-2"><i class="bi bi-facebook"></i></a>
                                    <a href="#" class="text-danger me-2"><i class="bi bi-instagram"></i></a>
                                    <a href="#" class="text-info"><i class="bi bi-linkedin"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>


        <!-- Call to Action -->
        <section class="py-5 text-center bg-primary text-white">
            <div class="container">
                <h2 class="mb-3">Ready to plan your next adventure?</h2>
                <a href="/contactUs" class="btn btn-light btn-lg">Contact Us</a>
            </div>
        </section>

        <!-- Footer Include -->
        <%- include ("./common/footer.ejs") %>

            <!-- Bootstrap JS -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>