<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Contact Us - Global Gateways</title>

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

  <style>
    body {
      background: linear-gradient(to right, #e0f7fa, #fff);
    }

    .contact-section {
      padding: 60px 0;
    }

    .contact-card {
      background: rgba(255, 255, 255, 0.9);
      backdrop-filter: blur(8px);
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .form-control,
    .form-select {
      border-radius: 10px;
    }

    .form-icon {
      color: #0d6efd;
      margin-right: 8px;
    }

    .contact-info {
      background-color: #0d6efd;
      color: white;
      border-radius: 20px 0 0 20px;
    }

    .contact-info h4 {
      font-weight: 600;
    }

    .contact-info i {
      margin-right: 8px;
    }

    @media (max-width: 768px) {
      .contact-info {
        border-radius: 20px 20px 0 0;
      }
    }
  </style>
</head>

<body>

  <!-- Header Include -->
  <%- include ("./common/header.ejs") %>

  <!-- Hero -->
  <section class="text-center bg-primary text-white py-5 mb-0">
    <div class="container">
      <h1 class="display-5 fw-bold">Contact Us</h1>
      <p class="lead">We’re always here to help you plan the perfect trip!</p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-10">
          <div class="row contact-card overflow-hidden">

            <!-- Contact Info -->
            <div class="col-md-4 contact-info p-4 d-flex flex-column justify-content-center">
              <h4 class="mb-4">Get in Touch</h4>
              <p><i class="bi bi-envelope-fill"></i> support@travelgo.com</p>
              <p><i class="bi bi-telephone-fill"></i> +1 800 123 4567</p>
              <p><i class="bi bi-geo-alt-fill"></i> 123 Traveler’s Lane, Wander City</p>
              <div class="mt-4">
                <a href="#" class="text-white me-3"><i class="bi bi-facebook fs-4"></i></a>
                <a href="#" class="text-white me-3"><i class="bi bi-instagram fs-4"></i></a>
                <a href="#" class="text-white"><i class="bi bi-twitter-x fs-4"></i></a>
              </div>
            </div>

            <!-- Form -->
            <div class="col-md-8 p-5">
              <form method="post" action="/contact">
                <div class="mb-4">
                  <label for="email" class="form-label">
                    <i class="bi bi-envelope-fill form-icon"></i>Email address
                  </label>
                  <input type="email" name="email" class="form-control" id="email" placeholder="name@example.com"
                    required>
                </div>

                <div class="mb-4">
                  <label for="phone" class="form-label">
                    <i class="bi bi-telephone-fill form-icon"></i>Phone number
                  </label>
                  <input type="tel" name="phone" class="form-control" id="phone" placeholder="Enter your number"
                    required>
                </div>

                <div class="mb-4">
                  <label for="query" class="form-label">
                    <i class="bi bi-question-circle-fill form-icon"></i>Select your query
                  </label>
                  <select class="form-select" name="query" id="query" required>
                    <option value="">-- Select an option --</option>
                    <option>General Inquiry</option>
                    <option>Package Details</option>
                    <option>Booking Assistance</option>
                    <option>Payment Issues</option>
                    <option>Other</option>
                  </select>
                </div>

                <div class="form-check mb-4">
                  <input class="form-check-input" name="member" type="checkbox" id="member">
                  <label class="form-check-label" for="member">
                    I am a registered member
                  </label>
                </div>

                <div class="mb-4">
                  <label for="concern" class="form-label">
                    <i class="bi bi-chat-dots-fill form-icon"></i>Elaborate your concern
                  </label>
                  <textarea class="form-control" name="concern" id="concern" rows="4"
                    placeholder="Write your message here..." required></textarea>
                </div>

                <div class="d-grid">
                  <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-send-fill me-1"></i> Submit
                  </button>
                </div>
              </form>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer Include -->
  <%- include ("./common/footer.ejs") %>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
