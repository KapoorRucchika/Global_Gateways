<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Our Travel Packages</title>

  <!-- Bootstrap 5.3.7 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
  <%- include ("./common/header.ejs") %>

  <!-- Hero / Title Section -->
  <section class="bg-primary text-white text-center py-5 mb-4">
    <div class="container">
      <h1 class="display-5 fw-bold">Explore Our Travel Packages</h1>
      <p class="lead">Discover hand-picked travel experiences tailored for you</p>
    </div>
  </section>

  <!-- Packages Section -->
  <div class="container py-4">
    <div class="row justify-content-center">

      <% if (packdata.length > 0) { %>
        <% for (var i = 0; i < packdata.length; i++) { %>
          <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm border-0">
              <img src="/uploads/<%= packdata[i].image %>" class="card-img-top" alt="Package Image"
                style="height: 200px; object-fit: cover; border-top-left-radius: .5rem; border-top-right-radius: .5rem;">
              <div class="card-body">
                <h5 class="card-title"><%= packdata[i].package %></h5>
                <p class="card-text mb-1"><strong>Country:</strong> <%= packdata[i].country %></p>
                <p class="card-text mb-1"><strong>Price:</strong> ₹<%= packdata[i].price %></p>
                <p class="card-text mb-1"><strong>Duration:</strong> <%= packdata[i].duration %></p>
                <p class="card-text mb-3"><strong>Phone No:</strong> <%= packdata[i].phone %></p>
                <a href="/view/<%= packdata[i]._id %>" class="btn btn-primary w-100">View Details</a>
              </div>
            </div>
          </div>
        <% } %>
      <% } else { %>
        <div class="col-12 text-center">
          <div class="alert alert-warning" role="alert">
            No travel packages found at the moment. Please check back later!
          </div>
        </div>
      <% } %>

    </div>
  </div>

  <%- include ("./common/footer.ejs") %>

  <!-- Bootstrap 5 JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
