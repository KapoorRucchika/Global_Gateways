<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap CSS (LTR) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
        integrity="sha384-..." crossorigin="anonymous">

    <title>Hello, world!</title>
</head>

<body>
    <div class="container-fluid bg-dark text-light mt-5 pt-5">
        <footer class="py-5">
            <div class="row">

                <!-- About Section -->
                <div class="col-md-3 mb-4">
                    <h5 class="text-uppercase">Global Gateways</h5>
                    <p>Your gateway to unforgettable journeys. Explore the world with our custom travel packages and
                        expert guidance.</p>
                </div>

                <!-- Popular Destinations -->
                <div class="col-md-2 mb-4">
                    <h6 class="text-uppercase">Destinations</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-light text-decoration-none">Paris</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Bali</a></li>
                        <li><a href="#" class="text-light text-decoration-none">New York</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Tokyo</a></li>
                    </ul>
                </div>

                <!-- Quick Links -->
                <div class="col-md-2 mb-4">
                    <h6 class="text-uppercase">Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-light text-decoration-none">Home</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Packages</a></li>
                        <li><a href="#" class="text-light text-decoration-none">Contact</a></li>
                        <li><a href="#" class="text-light text-decoration-none">FAQs</a></li>
                    </ul>
                </div>

                <!-- Contact Info -->
                <div class="col-md-2 mb-4">
                    <h6 class="text-uppercase">Contact</h6>
                    <ul class="list-unstyled text-light">
                        <li>Email: support@globegateways.com</li>
                        <li>Phone: +1 234 567 890</li>
                        <li>Location: New York, USA</li>
                    </ul>
                </div>

                <!-- Newsletter -->
                <div class="col-md-3 mb-4">
                    <h6 class="text-uppercase">Newsletter</h6>
                    <p>Get travel updates and offers in your inbox.</p>
                    <form>
                        <div class="input-group">
                            <input type="email" class="form-control" placeholder="Your email" aria-label="Email">
                            <button class="btn btn-primary" type="submit">Subscribe</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Bottom Row -->
            <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center border-top pt-4 mt-4">
                <p class="mb-2 mb-sm-0">© 2025 Global Gateways. All rights reserved.</p>
                <div>
                    <a href="#" class="text-light me-3"><i class="fab fa-facebook-f"></i></a>
                    <a href="#" class="text-light me-3"><i class="fab fa-instagram"></i></a>
                    <a href="#" class="text-light"><i class="fab fa-twitter"></i></a>
                </div>
            </div>
        </footer>
    </div>

    <!-- Font Awesome for Icons -->
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-..."
        crossorigin="anonymous"></script>
</body>


</html>